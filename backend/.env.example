# Runtime
ONT_AI_ENVIRONMENT=development
ONT_AI_LOG_LEVEL=INFO
ONT_AI_DATABASE_URL=sqlite+aiosqlite:///./data/opennutritracker_ai.db
ONT_AI_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Required in production. Send it as `Authorization: Bearer <token>`.
ONT_AI_ACCESS_TOKEN=
ONT_AI_RATE_LIMIT_REQUESTS=20
ONT_AI_RATE_LIMIT_WINDOW_SECONDS=60

# OpenAI. Leave empty to require a key from the app on every AI request.
ONT_AI_OPENAI_API_KEY=
ONT_AI_OPENAI_PRIMARY_MODEL=gpt-5.4-mini
ONT_AI_OPENAI_FALLBACK_MODEL=gpt-5.4
ONT_AI_OPENAI_TIMEOUT_SECONDS=45
